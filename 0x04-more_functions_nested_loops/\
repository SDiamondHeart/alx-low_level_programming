#include "main.h"

/**
 * print-traingle - user defined function for the code
 * @size: size of the triangle to print
 *
 * Description: prints a traingle followed by a new line
 *
 * Return: 0
 */

void prinnt_traingle(int size)
{
	int t;
	int u;

	if (size <= 0)
	{
		_putchar('\n');
	}
	for (t = 1; t <= size; t++)
	{
		for (u = 1; u <= size; u++)
		{
			if (u <= (size - 1))
			{
				_putchar(' ');
			}
			else
			{
				_putchar('#');
			}

			_putchar('\n');
		}
	}
}
